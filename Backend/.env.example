# ==========================================
# Backend Environment Variables
# ==========================================

PORT=5000

# MongoDB Atlas Connection String
# Replace <username>, <password> and <cluster>
#
# Note:
# If MongoDB Atlas DNS resolution fails with errors like:
# querySrv ECONNREFUSED _mongodb._tcp.<cluster>.mongodb.net
#
# You can temporarily use local MongoDB:
# MONGO_URL=mongodb://127.0.0.1:27017/attendance

MONGO_URL=mongodb+srv://MayankSingh:UPP6atcPN6bCAM1T@cluster0.hbcxbj5.mongodb.net/?AttendenceCloud1=Cluster0

# JWT Secret
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Frontend URL
CLIENT_URL=http://localhost:5173

# Optional: First Admin User (used by npm run seed)
SEED_ADMIN_EMAIL=admin@attendance.com
SEED_ADMIN_PASSWORD=admin123
